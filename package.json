{
  "name": "lego-dimensions-gui",
  "version": "1.0.0",
  "description": "Electron GUI for LEGO Dimensions with gamepad control",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "set NODE_ENV=development && electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.lego-dimensions.gui",
    "productName": "LEGO Dimensions Character Manager",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "data/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
